<?xml version="1.0" encoding="UTF-8"?>
<FrameDefaults xmlns="http://www.netex.org.uk/netex">
  <DefaultLocale>
    <!-- The default locale is German (de) for SBB and Swiss public transport. -->
    <TimeZoneOffset>1<!-- We prefer times without the suf-fix "+hh:mm". Instead we specify a default TimeZoneOffset (+2) and SummerTimeZoneOffset (+1) --></TimeZoneOffset>
    <SummerTimeZoneOffset>2<!-- We prefer times without the suf-fix "+hh:mm". Instead we specify a default TimeZoneOffset (+2) and SummerTimeZoneOffset (+1) --></SummerTimeZoneOffset>
    <DefaultLanguage>de<!-- Is always set to “de” for SKI and Swiss public transport. --></DefaultLanguage>
  </DefaultLocale>
</FrameDefaults>
